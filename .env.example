# ── Core runtime ──────────────────────────────────────────────────────────
# Set NODE_ENV=production in prod to enable secure cookies + other hardening.
NODE_ENV=development
API_PORT=3000
WEB_ORIGIN=http://localhost:5173
API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:3000
# ── Production values (single-box deploy behind Cloudflare) ────────────────
# Copy this file to .env on the box and switch the values above to:
#   NODE_ENV=production
#   WEB_ORIGIN=https://bonelessisland.com
#   API_BASE_URL=https://api.bonelessisland.com
# VITE_API_BASE_URL is baked into the web image at build time via the compose
# build arg (infra/docker-compose.yml), not read from here in prod.
#
# Secrets source — leave unset for env-file mode (this file holds all secrets).
# Set to "ssm" to pull /boneless/prod/* from AWS SSM Parameter Store at startup
# (requires NODE_ENV=production + the EC2 instance role; see DEPLOY.md).
# SECRETS_SOURCE=ssm
# AWS_REGION=us-east-1

# ── Database ──────────────────────────────────────────────────────────────
# Local dev format. In prod use the platform's connection string (RDS, Neon,
# Supabase) and ensure the password is URL-safe (no characters needing encoding).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/boneless
# Postgres container password — must match the password segment of DATABASE_URL.
# Used by infra/docker-compose.yml at volume init. Generate URL-safe with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
POSTGRES_PASSWORD=postgres

# ── Sessions ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=replace-with-strong-random-secret
# Optional — set during rotation. When present, old cookies still verify
# while new ones are signed with SESSION_SECRET. Remove after old sessions
# expire (~30 days).
# SESSION_SECRET_PREVIOUS=previous-secret-here

# ── Discord OAuth (website login — "The Boneless Island" app) ─────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback
DISCORD_GUILD_ID=
# Exact Discord role name whose holders get admin access. Case-sensitive.
PARENT_ROLE_NAME=Parent

# ── Discord bot (Nuggie app) ──────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_BOT_CLIENT_ID=
# Shared by API + bot. Bot includes it as x-island-bot-secret header on every
# /internal/* call. Generate with the same node one-liner as SESSION_SECRET.
BOT_API_SHARED_SECRET=replace-with-shared-secret-used-by-api-and-bot

# ── Steam (optional — Steam linking, wishlist sync, achievements) ─────────
# Register at https://steamcommunity.com/dev/apikey
STEAM_WEB_API_KEY=

# ── IGDB (optional — richer game metadata + image fallback) ───────────────
# Register a Twitch dev app + get IGDB credentials at https://api-docs.igdb.com
IGDB_IMAGE_FALLBACK_ENABLED=false
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# ── AI providers (optional — only the chosen provider's key is required) ──
# Provider selection happens in the admin UI (Admin → System → AI Settings).
# Per-provider keys can be stored in DB via the admin UI instead of env;
# values here act as fallback if DB key not set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
