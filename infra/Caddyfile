# Caddy config for the single-box deploy.
#
# Topology:  Cloudflare (DNS + proxy, TLS at edge) → Caddy (this) → app containers
#
# Caddy terminates TLS on the box using a Cloudflare Origin CA certificate
# (free, 15-year, covers bonelessisland.com + *.bonelessisland.com). Set the
# Cloudflare SSL/TLS mode to "Full (strict)" so the edge verifies this cert.
# Mount the cert + key into the container at /certs (see docker-compose.yml).
#
# It serves two hostnames:
#   bonelessisland.com      → the static React build (SPA) baked into this image
#   api.bonelessisland.com  → reverse proxy to the api container on :3000
#
# Refresh the Cloudflare IP ranges below from https://www.cloudflare.com/ips/
# if Cloudflare ever changes them (rare). They must match the EC2 security
# group ingress rules — origin should only be reachable through Cloudflare.
{
	# Restore the true visitor IP from Cloudflare's trusted header so the
	# X-Forwarded-For Caddy sends upstream (and thus Express's req.ip) is the
	# real client, not a Cloudflare edge IP. Only trust XFF/Cf-Connecting-IP
	# when the immediate peer is a Cloudflare address.
	servers {
		client_ip_headers Cf-Connecting-IP
		trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
	}
}

# Shared security response headers, imported by each site block below.
# HSTS is set at Cloudflare's edge, so it's intentionally NOT duplicated here.
# A Content-Security-Policy is deferred until it can be tuned against the SPA.
(security_headers) {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		-Server
	}
}

# ── Apex: static SPA ────────────────────────────────────────────────────────
bonelessisland.com {
	tls /certs/origin-cert.pem /certs/origin-key.pem
	import security_headers

	# Content-Security-Policy shipped Report-Only first: violations POST to the
	# API's /csp-reports endpoint instead of being blocked. Flip the header name
	# to `Content-Security-Policy` (enforcing) once a week of prod reports comes
	# back clean. Notes on the non-obvious sources:
	#   script-src   'self' (our external bundle) + a per-request nonce +
	#                Cloudflare's Web Analytics beacon. The SPA ships no inline
	#                scripts of its own. The nonce is there so Cloudflare can
	#                stamp it onto the inline scripts IT injects — JavaScript
	#                Detections (Bot Fight Mode) can't be disabled on the free
	#                plan, and CF parses this CSP response header and applies the
	#                nonce to its injected scripts. {http.request.uuid} is a
	#                per-request random UUID; browsers match nonces by literal
	#                string compare so the hyphens are fine. Keep Rocket Loader
	#                OFF (its inline scripts are injected too late to be nonced).
	#                NOTE: still Report-Only — we're soaking to confirm CF nonces
	#                the JSD scripts before flipping this to enforcing.
	#   connect-src  adds cloudflareinsights.com so the beacon can POST metrics.
	#   img-src      'https:' allows any HTTPS image. News cards hotlink cover art
	#                and source favicons from arbitrary outlet CDNs that can't be
	#                enumerated (plus Discord/Steam art + Google's s2 favicon
	#                proxy). Images can't execute, so a scheme-level https relax is
	#                acceptable here; every other directive stays strict. data:/blob:
	#                cover inline + generated (canvas) images.
	#   media-src    'self' for the self-hosted scene + auth cinematic videos.
	#   style-src    'unsafe-inline' is required for React inline styles.
	header {
		Content-Security-Policy-Report-Only "default-src 'none'; script-src 'self' 'nonce-{http.request.uuid}' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; media-src 'self'; connect-src 'self' https://api.bonelessisland.com https://cloudflareinsights.com; manifest-src 'self'; base-uri 'none'; form-action 'self'; frame-ancestors 'none'; report-uri https://api.bonelessisland.com/csp-reports; report-to csp"
		Reporting-Endpoints `csp="https://api.bonelessisland.com/csp-reports"`
	}

	root * /srv
	encode zstd gzip

	# Client-side app: serve real files when they exist, otherwise fall back to
	# index.html so deep links (real React Router paths) and OAuth return URLs
	# resolve. Serve precompressed .br/.gz sidecars (emitted by
	# vite-plugin-compression2) directly — Caddy can't brotli on the fly.
	try_files {path} /index.html
	file_server {
		precompressed br zstd gzip
	}

	# Fingerprinted assets are immutable → cache a year. no-transform stops
	# Cloudflare from re-compressing (which would discard our brotli). Everything
	# else is the HTML shell, served for every route via try_files, and must
	# revalidate so a deploy takes effect immediately (no stale shell).
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable, no-transform"
	@milestones path /art/milestones/*
	header @milestones Cache-Control "public, max-age=31536000, immutable, no-transform"
	@notassets not path /assets/*
	header @notassets Cache-Control "no-cache"
}

# ── www → apex redirect ─────────────────────────────────────────────────────
www.bonelessisland.com {
	tls /certs/origin-cert.pem /certs/origin-key.pem
	redir https://bonelessisland.com{uri} permanent
}

# ── API ─────────────────────────────────────────────────────────────────────
api.bonelessisland.com {
	tls /certs/origin-cert.pem /certs/origin-key.pem
	import security_headers

	# /internal/* serves the bot only, over the private docker network
	# (API_BASE_URL=http://api:3000). It never needs public reachability —
	# block it at the edge as defense in depth (it's also shared-secret gated).
	# `handle` blocks are mutually exclusive + evaluated in order, so this is
	# guaranteed to short-circuit before the proxy regardless of directive order.
	handle /internal* {
		respond 403
	}

	handle {
		reverse_proxy api:3000
	}
}
