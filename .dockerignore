# Keep build context small + prevent secrets/local state from sneaking into images.
.git
.github
.cursor
.claude

# Local environment + secrets — NEVER include in image. Inject at deploy time.
.env
.env.*
!.env.example

# Node + build artifacts (re-created in the builder stage)
node_modules
**/node_modules
**/dist
**/.tsbuildinfo
**/coverage

# Editor / OS junk
.vscode
.idea
.DS_Store
Thumbs.db

# Docs + assets that don't need to be in the container
*.md
README*
.design-handoff

# Web app build artifact — re-created in the web image's builder stage.
# (apps/web/public IS needed: Vite copies it into dist, so keep it in context.)
apps/web/dist

# Infra files (compose, terraform, etc.) aren't needed by the api/bot images,
# but the web image bakes in the Caddy config — re-include just that file.
infra
!infra/Caddyfile
